# ── Supabase ───────────────────────────────────────────────────────
# Painel do projeto Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave "service_role" — só usada no servidor (nunca expor no client). Necessária pro worker de disparo.
SUPABASE_SERVICE_ROLE_KEY=

# ── E-mail (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=

# ── Claude (Anthropic) — agentes de IA ────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# ── Evolution API (WhatsApp) ──────────────────────────────────────
EVOLUTION_URL=
EVOLUTION_APIKEY=
# URL pública deste app (Vercel) + ?secret=<mesmo valor de WHATSAPP_WEBHOOK_SECRET abaixo>
EVOLUTION_WEBHOOK_URL=
# Segredo compartilhado que valida quem chama /api/webhook/whatsapp — gere com:
# python3 -c "import secrets; print(secrets.token_urlsafe(24))"
WHATSAPP_WEBHOOK_SECRET=
